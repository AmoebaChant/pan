{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AmoebaChant/pan/schema/playbook.json",
  "title": "PAN runner playbook",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "capacity",
    "capabilities",
    "repositories"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "capacity": { "type": "integer", "minimum": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "instructions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "delivery": {
      "enum": ["pull-request", "direct"],
      "default": "pull-request",
      "description": "Omit for pull-request delivery. Set direct only when this playbook is explicitly authorized to integrate and push to the configured default branch."
    }
  }
}
