{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AmoebaChant/pan/schema/runner-profile.json",
  "title": "PAN runner capability profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "id",
    "machine",
    "online",
    "maxConcurrentDaemons",
    "capabilities",
    "store",
    "repositories",
    "workspaceRoot",
    "stateDirectory",
    "terminal"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "machine": { "type": "string", "minLength": 1 },
    "online": { "type": "boolean" },
    "maxConcurrentDaemons": { "type": "integer", "minimum": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "playbooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "playbook.json"
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "projectOwner", "projectNumber"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "projectOwner": { "type": "string", "minLength": 1 },
        "projectNumber": { "type": "integer", "minimum": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "repositories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "defaultBranch"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "defaultBranch": { "type": "string", "minLength": 1 }
        }
      }
    },
    "workspaceRoot": { "type": "string", "minLength": 1 },
    "stateDirectory": { "type": "string", "minLength": 1 },
    "githubAssignee": { "type": "string", "minLength": 1 },
    "domainConfigPath": { "type": "string", "minLength": 1 },
    "pollIntervalSeconds": { "type": "number", "exclusiveMinimum": 0 },
    "leaseSeconds": { "type": "number", "exclusiveMinimum": 0 },
    "heartbeatSeconds": { "type": "number", "exclusiveMinimum": 0 },
    "taskBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wallClockMinutes": { "type": "number", "exclusiveMinimum": 0 },
        "maxAiCredits": { "type": "number", "minimum": 30 },
        "maxAutopilotContinues": { "type": "integer", "minimum": 1 }
      }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "windows-terminal" },
        "executable": { "type": "string", "minLength": 1 },
        "window": { "type": "string", "minLength": 1 },
        "profile": {
          "type": "string",
          "minLength": 1,
          "description": "Optional Windows Terminal profile name for this machine."
        }
      }
    },
    "copilot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executable": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "approvalMode": {
          "type": "string",
          "enum": ["prompt", "allow-all"],
          "default": "prompt"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "online": { "const": true }
        },
        "required": ["online"]
      },
      "then": {
        "properties": {
          "repositories": { "minProperties": 1 }
        }
      }
    }
  ]
}
