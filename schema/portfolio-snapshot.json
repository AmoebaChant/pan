{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AmoebaChant/pan/schema/portfolio-snapshot.json",
  "title": "PAN portfolio evidence snapshot",
  "description": "Complete domain evidence and expected-state identities used to authorize PAN recommendations and mutations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "capturedAt",
    "complete",
    "usableForMutation",
    "source",
    "expectedState",
    "project",
    "issueCatalog",
    "workstreams",
    "runnerAvailability",
    "dossiers",
    "diagnostics"
  ],
  "properties": {
    "id": { "$ref": "#/$defs/identity" },
    "version": { "const": 2 },
    "capturedAt": { "type": "string", "format": "date-time" },
    "complete": { "type": "boolean" },
    "usableForMutation": { "type": "boolean" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "issues", "workstreams", "runners"]
    },
    "expectedState": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/identity" },
      "required": [
        "projectOrder",
        "projectItems",
        "projectFields",
        "projectMembership",
        "issueCatalog",
        "workstreamIndex",
        "workstreamBlobs",
        "attentionRecords",
        "leadershipGeneration"
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "items"],
      "properties": {
        "id": { "$ref": "#/$defs/identity" },
        "items": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "issueCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "excludedPullRequests"],
      "properties": {
        "id": { "$ref": "#/$defs/identity" },
        "excludedPullRequests": { "type": "integer", "minimum": 0 }
      }
    },
    "workstreams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revision"],
      "properties": {
        "revision": { "$ref": "#/$defs/identity" }
      }
    },
    "runnerAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["complete", "runners"],
      "properties": {
        "complete": { "type": "boolean" },
        "runners": { "type": "array" }
      }
    },
    "dossiers": { "type": "array" },
    "diagnostics": { "type": "array" }
  },
  "$defs": {
    "identity": { "type": "string", "minLength": 1 }
  }
}
