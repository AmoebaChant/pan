{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AmoebaChant/pan/schema/domain-config.json",
  "title": "PAN domain runtime configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "domain",
    "state",
    "agent"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "projectOwner",
        "projectNumber",
        "path"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9._-]+$"
        },
        "projectOwner": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9-]*$"
        },
        "projectNumber": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "branch",
        "path"
      ],
      "properties": {
        "branch": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "executable": {
          "type": "string",
          "minLength": 1,
          "default": "copilot"
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "turnTimeoutSeconds": {
          "type": "number",
          "minimum": 30,
          "maximum": 3600
        },
        "maxAiCredits": {
          "type": "number",
          "minimum": 1,
          "maximum": 1000
        }
      }
    },
    "cadences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activePollSeconds": {
          "type": "number",
          "minimum": 5,
          "maximum": 300,
          "default": 30
        },
        "idlePollSeconds": {
          "type": "number",
          "minimum": 30,
          "maximum": 3600,
          "default": 300
        },
        "fullReviewSeconds": {
          "type": "number",
          "minimum": 300,
          "maximum": 604800,
          "default": 86400
        },
        "leaderLeaseSeconds": {
          "type": "number",
          "minimum": 30,
          "maximum": 3600,
          "default": 120
        },
        "leaderHeartbeatSeconds": {
          "type": "number",
          "minimum": 5,
          "maximum": 1200,
          "default": 30
        },
        "notificationSeconds": {
          "type": "number",
          "minimum": 30,
          "maximum": 86400,
          "default": 300
        },
        "retrySeconds": {
          "type": "number",
          "minimum": 5,
          "maximum": 3600,
          "default": 60
        },
        "rateLimitRetrySeconds": {
          "type": "number",
          "minimum": 60,
          "maximum": 86400,
          "default": 900
        }
      }
    },
    "transcripts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
        },
        "retentionDays": {
          "type": "integer",
          "minimum": 1,
          "maximum": 365,
          "default": 30
        }
      }
    },
    "reviewPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "higherRisk": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "actionKinds": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            }
          }
        }
      }
    },
    "attention": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assignee": {
          "type": "string",
          "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"
        }
      }
    },
    "selfRepair": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "repository": {
            "type": "string",
            "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9._-]+$"
          },
          "workstream": {
            "type": "string",
            "minLength": 1
          },
          "requirements": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "not": {
                "pattern": "^(repo|delivery):"
              }
            },
            "default": []
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "enabled": {
                  "const": true
                }
              },
              "required": [
                "enabled"
              ]
            },
            "then": {
              "required": [
                "repository",
                "workstream"
              ]
            }
          }
        ]
    }
  }
}
